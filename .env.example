DATABASE_URL=postgresql://crrt:crrt@localhost:5432/crrt?schema=public
NEXTAUTH_SECRET=replace-with-long-random-secret
NEXTAUTH_URL=http://localhost:3300
ADMIN_EMAIL=contact@crrt.tech

# Optional for email workflows (fallback logs to console if missing)
SMTP_HOST=smtp.purelymail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=CRRT <contact@crrt.tech>

# Optional for admin inbox sync (Purelymail defaults)
IMAP_HOST=imap.purelymail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_PASS=
IMAP_FOLDER_INBOX=INBOX
IMAP_FOLDER_SENT=Sent
IMAP_FOLDER_DRAFTS=Drafts
IMAP_FOLDER_ARCHIVE=Archive
IMAP_FOLDER_TRASH=Trash
IMAP_SYNC_INTERVAL_SECONDS=30
IMAP_INITIAL_SYNC_DAYS=90

# Optional media tuning
MEDIA_MAX_UPLOAD_BYTES=10485760
