{
  "name": "crrt",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3300",
    "dev:docker": "docker compose -f docker-compose.dev.yml up --build --watch",
    "dev:docker:up": "docker compose -f docker-compose.dev.yml up --build",
    "dev:docker:down": "docker compose -f docker-compose.dev.yml down",
    "dev:docker:logs": "docker compose -f docker-compose.dev.yml logs -f app postgres",
    "dev:docker:seed": "docker compose -f docker-compose.dev.yml run --rm app npm run db:seed",
    "dev:docker:reset": "docker compose -f docker-compose.dev.yml run --rm app npm run db:reset",
    "build": "next build --webpack",
    "start": "next start --port 3300",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:migrate": "npx prisma migrate dev",
    "db:deploy": "npx prisma migrate deploy && npm run db:backfill:forms",
    "db:backfill:forms": "npx tsx prisma/backfill-form-submissions.ts",
    "db:seed": "npm exec -- tsx prisma/seed.ts",
    "db:reset": "npx prisma migrate reset",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/nodemailer": "^7.0.11",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.34.3",
    "html-to-text": "^9.0.5",
    "imapflow": "^1.2.13",
    "lucide-react": "^0.575.0",
    "mailparser": "^3.9.4",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.13",
    "prisma": "^6.19.2",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sanitize-html": "^2.17.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
