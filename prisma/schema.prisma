generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // hashed password for credentials login
  role          String    @default("member") // admin | member
  mustRotatePassword Boolean @default(false)
  phone         String?
  bio           String?
  organization  String?
  city          String?
  accounts      Account[]
  sessions      Session[]
  registrations EventRegistration[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Content ─────────────────────────────────────

model Event {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  content     String   @default("")
  type        String   @default("workshop") // training | conference | competition | workshop | hackathon
  status      String   @default("draft") // draft | published | archived
  coverImage  String?
  location    String?
  startDate   DateTime
  endDate     DateTime?
  capacity    Int?
  themePreset String   @default("default") // default | ocean | forest | sunset | slate
  themeAccent String?
  registrationMode  String   @default("internal") // closed | internal | external
  registrationLabel String?
  registrationUrl   String?
  registrationReviewMode String @default("auto") // auto | manual
  publishStart DateTime?
  publishEnd   DateTime?
  published   Boolean  @default(false)
  tags        ContentTag[]
  speakers    EventSpeaker[]
  registrations EventRegistration[]
  form        Form?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EventSpeaker {
  id       String @id @default(cuid())
  eventId  String
  name     String
  role     String?
  bio      String?
  image    String?
  order    Int    @default(0)
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  content     String   @default("")
  status      String   @default("ongoing") // ongoing | completed | archived
  coverImage  String?
  repoUrl     String?
  demoUrl     String?
  stackTags   Json     @default("[]")
  year        Int?
  published   Boolean  @default(false)
  tags        ContentTag[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String   @default("")
  coverImage  String?
  authorId    String?
  published   Boolean  @default(false)
  tags        ContentTag[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Tags ────────────────────────────────────────

model Tag {
  id       String       @id @default(cuid())
  name     String       @unique
  labelFr  String?
  labelAr  String?
  labelEn  String?
  color    String?
  icon     String?
  contents ContentTag[]
}

model ContentTag {
  id        String  @id @default(cuid())
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  eventId   String?
  event     Event?  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  postId    String?
  post      Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)
}

// ─── Media ───────────────────────────────────────

model Media {
  id        String   @id @default(cuid())
  filename  String
  url       String
  mimeType  String
  size      Int
  alt       String?
  usedIn    String?
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
}

// ─── Resources ─────────────────────────────────────

model ResourceCategory {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  color       String?
  icon        String?
  resources   Resource[]
}

model Resource {
  id          String           @id @default(cuid())
  title       String
  slug        String           @unique
  description String
  url         String           // External link or internal media URL
  type        String           @default("document") // document | video | link | repository
  isPublic    Boolean          @default(true) // If false, only logged-in members can view
  categoryId  String
  category    ResourceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

// ─── Forms ───────────────────────────────────────

model Form {
  id              String           @id @default(cuid())
  title           String
  slug            String           @unique
  description     String?
  status          String           @default("draft") // draft | published | closed
  version         Int              @default(1)
  template        String?          // training | competition | membership | sponsor | null
  emailTemplateId String?
  spamProtection  Boolean          @default(false)
  eventId         String?          @unique
  event           Event?           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sections        FormSection[]
  fields          FormField[]
  submissions     FormSubmission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model FormSection {
  id          String     @id @default(cuid())
  formId      String
  form        Form       @relation(fields: [formId], references: [id], onDelete: Cascade)
  title       String
  description String?
  visibility  Json?
  order       Int        @default(0)
  fields      FormField[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([formId, order])
}

model FormField {
  id           String  @id @default(cuid())
  formId       String
  form         Form    @relation(fields: [formId], references: [id], onDelete: Cascade)
  sectionId    String?
  section      FormSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  type         String  // text | textarea | select | checkbox | radio | date | file | repeater
  label        String
  placeholder  String?
  required     Boolean @default(false)
  options      Json?
  validation   Json?
  visibility   Json?
  config       Json?
  order        Int     @default(0)
  page         Int     @default(0)

  @@index([formId, sectionId, order])
}

model FormSubmission {
  id                    String              @id @default(cuid())
  formId                String
  form                  Form                @relation(fields: [formId], references: [id], onDelete: Cascade)
  eventRegistrationId   String?             @unique
  eventRegistration     EventRegistration?  @relation(fields: [eventRegistrationId], references: [id], onDelete: SetNull)
  status                String              @default("new") // new | in_review | accepted | rejected
  schemaVersion         Int                 @default(1)
  data                  Json                @default("{}")
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
}

// ─── Config Singletons ───────────────────────────

model ThemeSettings {
  id               String @id @default("default")
  primaryColor     String @default("#F97316")
  backgroundColor  String @default("#0F172A")
  accentColor      String @default("#F97316")
  radius           Int    @default(16)
  shadowStrength   String @default("medium")
  glassIntensity   String @default("medium") // off | low | medium
  noiseOverlay     String @default("subtle") // off | subtle
  motionLevel      String @default("standard") // off | subtle | standard
  heroVariant      String @default("A")
  cardVariant      String @default("elevated") // flat | elevated | glass
  timelineVariant  String @default("blueprint") // minimal | blueprint
  logoLight        String?
  logoDark         String?
  favicon          String?
  updatedAt        DateTime @updatedAt
}

model HomeConfig {
  id                 String @id @default("default")
  missionText        String @default("Club Robotique & Recherche Technologique")
  tagline            String @default("Our robots never sleep.")
  pinnedEventId      String?
  featuredProjectIds Json   @default("[]")
  trackTagMap        Json   @default("[]")
  sponsorIds         Json   @default("[]")
  updatedAt          DateTime @updatedAt
}

model PlatformSettings {
  id          String   @id @default("default")
  siteTitle   String   @default("CRRT - ENSA Agadir")
  siteUrl     String   @default("https://crrt.ensa-agadir.ac.ma")
  adminEmail  String?
  smtpHost    String?
  smtpPort    Int?
  smtpFrom    String?
  imapHost    String?
  imapPort    Int?
  imapSecure  Boolean?
  imapFolderInbox   String?
  imapFolderSent    String?
  imapFolderDrafts  String?
  imapFolderArchive String?
  imapFolderTrash   String?
  imapSyncIntervalSeconds Int?
  imapInitialSyncDays     Int?
  updatedAt   DateTime @updatedAt
}

model EmailTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  subject   String
  body      String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MailThread {
  id             String        @id @default(cuid())
  mailbox        String        @default("shared")
  threadKey      String
  subject        String?
  participants   Json          @default("[]")
  snippet        String?
  lastMessageAt  DateTime?
  unreadCount    Int           @default(0)
  hasAttachments Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  messages       MailMessage[]
  drafts         MailDraft[]

  @@unique([mailbox, threadKey])
  @@index([mailbox, lastMessageAt])
}

model MailMessage {
  id               String            @id @default(cuid())
  mailbox          String            @default("shared")
  threadId         String
  thread           MailThread        @relation(fields: [threadId], references: [id], onDelete: Cascade)
  messageIdHeader  String?
  inReplyTo        String?
  references       Json              @default("[]")
  imapFolder       String
  imapUidValidity  BigInt?
  imapUid          Int?
  fromName         String?
  fromEmail        String?
  toRecipients     Json              @default("[]")
  ccRecipients     Json              @default("[]")
  bccRecipients    Json              @default("[]")
  subject          String            @default("")
  snippet          String?
  textBody         String?
  htmlBody         String?
  rawMime          Bytes?
  rawMimeEncoding  String?
  date             DateTime
  internalDate     DateTime?
  isRead           Boolean           @default(false)
  isFlagged        Boolean           @default(false)
  isDraft          Boolean           @default(false)
  isSent           Boolean           @default(false)
  direction        String            @default("inbound") // inbound | outbound
  appendPending    Boolean           @default(false)
  appendError      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  attachments      MailAttachment[]

  @@unique([imapFolder, imapUidValidity, imapUid])
  @@index([mailbox, imapFolder, date])
  @@index([threadId, date])
  @@index([messageIdHeader])
}

model MailAttachment {
  id             String      @id @default(cuid())
  messageId      String
  message        MailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  filename       String
  mimeType       String
  size           Int
  contentId      String?
  isInline       Boolean     @default(false)
  rawContent     Bytes?
  transferEncoding String?
  createdAt      DateTime    @default(now())

  @@index([messageId])
}

model MailDraft {
  id              String               @id @default(cuid())
  mailbox         String               @default("shared")
  threadId        String?
  thread          MailThread?          @relation(fields: [threadId], references: [id], onDelete: SetNull)
  remoteUidValidity BigInt?
  remoteUid       Int?
  toRecipients    Json                 @default("[]")
  ccRecipients    Json                 @default("[]")
  bccRecipients   Json                 @default("[]")
  subject         String               @default("")
  htmlBody        String               @default("")
  textBody        String               @default("")
  version         Int                  @default(1)
  status          String               @default("active") // active | sending | sent
  lastError       String?
  createdByEmail  String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  attachments     MailDraftAttachment[]

  @@index([mailbox, updatedAt])
}

model MailDraftAttachment {
  id         String    @id @default(cuid())
  draftId    String
  draft      MailDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  filename   String
  mimeType   String
  size       Int
  content    Bytes
  createdAt  DateTime  @default(now())

  @@index([draftId])
}

model MailFolderCursor {
  id             String   @id @default(cuid())
  mailbox        String   @default("shared")
  folderKey      String
  folderName     String
  uidValidity    BigInt?
  highestUid     Int?
  lastSyncedAt   DateTime?
  syncStatus     String   @default("idle") // idle | running | success | failed
  lastError      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([mailbox, folderKey])
}

enum EventRegistrationStatus {
  registered
  waitlisted
  approved
  rejected
  cancelled
}

model EventRegistration {
  id          String                  @id @default(cuid())
  eventId     String
  userId      String
  status      EventRegistrationStatus @default(registered)
  note        String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  waitlistedAt DateTime?
  approvedAt   DateTime?
  rejectedAt   DateTime?
  cancelledAt  DateTime?
  event       Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  formSubmission FormSubmission?

  @@unique([eventId, userId])
  @@index([eventId, status])
  @@index([userId, status])
}

model NavItem {
  id       String  @id @default(cuid())
  label    String
  href     String
  order    Int     @default(0)
  parentId String?
  visible  Boolean @default(true)
  section  String  @default("main") // main | footer | header
}

model TimelineMilestone {
  id          String @id @default(cuid())
  year        Int
  title       String
  description String?
  order       Int    @default(0)
}

model Partner {
  id       String @id @default(cuid())
  name     String
  logoUrl  String
  website  String?
  order    Int    @default(0)
}

model TeamMember {
  id       String  @id @default(cuid())
  name     String
  role     String
  image    String?
  linkedIn String?
  isAlumni Boolean @default(false)
  order    Int     @default(0)
}
