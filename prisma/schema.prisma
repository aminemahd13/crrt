generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("member") // admin | editor | member
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Content ─────────────────────────────────────

model Event {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  content     String   @default("")
  type        String   @default("workshop") // training | conference | competition | workshop
  status      String   @default("draft") // draft | published | archived
  coverImage  String?
  location    String?
  startDate   DateTime
  endDate     DateTime?
  capacity    Int?
  published   Boolean  @default(false)
  tags        ContentTag[]
  speakers    EventSpeaker[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EventSpeaker {
  id       String @id @default(cuid())
  eventId  String
  name     String
  role     String?
  bio      String?
  image    String?
  order    Int    @default(0)
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  content     String   @default("")
  status      String   @default("ongoing") // ongoing | completed | archived
  coverImage  String?
  repoUrl     String?
  demoUrl     String?
  stackTags   String   @default("[]") // JSON array of tech stack strings
  year        Int?
  published   Boolean  @default(false)
  tags        ContentTag[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String   @default("")
  coverImage  String?
  authorId    String?
  published   Boolean  @default(false)
  tags        ContentTag[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Tags ────────────────────────────────────────

model Tag {
  id       String       @id @default(cuid())
  name     String       @unique
  labelFr  String?
  labelAr  String?
  labelEn  String?
  color    String?
  icon     String?
  contents ContentTag[]
}

model ContentTag {
  id        String  @id @default(cuid())
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  eventId   String?
  event     Event?  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  postId    String?
  post      Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)
}

// ─── Media ───────────────────────────────────────

model Media {
  id        String   @id @default(cuid())
  filename  String
  url       String
  mimeType  String
  size      Int
  alt       String?
  usedIn    String?
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
}

// ─── Forms ───────────────────────────────────────

model Form {
  id              String           @id @default(cuid())
  title           String
  slug            String           @unique
  description     String?
  status          String           @default("draft") // draft | published | closed
  version         Int              @default(1)
  template        String?          // training | competition | membership | sponsor | null
  emailTemplateId String?
  spamProtection  Boolean          @default(false)
  fields          FormField[]
  submissions     FormSubmission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model FormField {
  id           String  @id @default(cuid())
  formId       String
  form         Form    @relation(fields: [formId], references: [id], onDelete: Cascade)
  type         String  // text | textarea | select | checkbox | radio | date | file | repeater
  label        String
  placeholder  String?
  required     Boolean @default(false)
  options      String? // JSON for select/radio/checkbox options
  validation   String? // JSON for validation rules
  order        Int     @default(0)
  page         Int     @default(0)
}

model FormSubmission {
  id        String                @id @default(cuid())
  formId    String
  form      Form                  @relation(fields: [formId], references: [id], onDelete: Cascade)
  status    String                @default("new") // new | in_review | accepted | rejected
  data      String                @default("{}") // JSON of field values
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
}

// ─── Config Singletons ───────────────────────────

model ThemeSettings {
  id               String @id @default("default")
  primaryColor     String @default("#F97316")
  backgroundColor  String @default("#0F172A")
  accentColor      String @default("#F97316")
  radius           Int    @default(16)
  shadowStrength   String @default("medium")
  glassIntensity   String @default("medium") // off | low | medium
  noiseOverlay     String @default("subtle") // off | subtle
  motionLevel      String @default("standard") // off | subtle | standard
  heroVariant      String @default("A")
  cardVariant      String @default("elevated") // flat | elevated | glass
  timelineVariant  String @default("blueprint") // minimal | blueprint
  logoLight        String?
  logoDark         String?
  favicon          String?
  updatedAt        DateTime @updatedAt
}

model HomeConfig {
  id                 String @id @default("default")
  missionText        String @default("Club Robotique & Recherche Technologique")
  tagline            String @default("Our robots never sleep.")
  pinnedEventId      String?
  featuredProjectIds String @default("[]") // JSON array
  trackTagMap        String @default("[]") // JSON array of {tag, label, icon}
  sponsorIds         String @default("[]") // JSON array
  updatedAt          DateTime @updatedAt
}

model NavItem {
  id       String  @id @default(cuid())
  label    String
  href     String
  order    Int     @default(0)
  parentId String?
  visible  Boolean @default(true)
  section  String  @default("main") // main | footer | header
}

model TimelineMilestone {
  id          String @id @default(cuid())
  year        Int
  title       String
  description String?
  order       Int    @default(0)
}

model Partner {
  id       String @id @default(cuid())
  name     String
  logoUrl  String
  website  String?
  order    Int    @default(0)
}

model TeamMember {
  id       String  @id @default(cuid())
  name     String
  role     String
  image    String?
  linkedIn String?
  isAlumni Boolean @default(false)
  order    Int     @default(0)
}
